# GitLab Self-Hosted Configuration
# Copy to .env and fill in values

# GitLab server URL (no trailing slash)
GITLAB_DOMAIN="https://devops.nhc.sa"

# Personal Access Token with 'api' scope
# Create at: Settings > Access Tokens > Add new token
GITLAB_TOKEN="glpat-BJq-OkW34ppsaWIAZ7_08W86MQp1OnV6CA.01.0y1ggoocx"

# Project namespace (group path) for multi-repo architecture
# Use with: -p "repo-name" -> resolves to "namespace/repo-name"
GITLAB_PROJECT_NAMESPACE="ejar3/devs"

# Default project ID (optional, full path)
# Can be numeric ID or path (group/subgroup/project)
# If set, used when -p flag is omitted
GITLAB_PROJECT_ID=""
